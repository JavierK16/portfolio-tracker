# Portfolio Tracker — Environment Variables
# Copy this file to .env and fill in your API keys.

# Finnhub (free tier: https://finnhub.io/register)
# Used as fallback when yfinance fails for a ticker.
FINNHUB_API_KEY=your_finnhub_api_key_here

# NewsAPI (optional: https://newsapi.org/register)
# Supplements RSS feeds with additional geopolitical coverage.
NEWSAPI_KEY=your_newsapi_key_here
